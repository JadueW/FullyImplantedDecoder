      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="trial_ready"/>
    <Routine name="action"/>
    <Routine name="trial_over"/>
    <Routine name="inter_trial_interval"/>
    <LoopTerminator name="trial_loop"/>
    <Routine name="block_over"/>
    <LoopTerminator name="block_loop"/>
    <Routine name="finish"/>
  </Flow>
