      <CodeComponent name="act_code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="act_movie_dir = os.path.join(video_dir, video_name)&amp;#10;act_sound_dir = os.path.join(sound_dir, &quot;开始.wav&quot;)&amp;#10;global global_decode_id&amp;#10;&amp;#10;action_start_time_s = monotonic_time_s()&amp;#10;action_end_time_s = 0.0&amp;#10;action_now_s = 0.0&amp;#10;action_last_fetch_s = action_start_time_s&amp;#10;&amp;#10;action_decode_count = 0&amp;#10;action_log_cache = []&amp;#10;action_pending_chunk_shape_by_id = {}&amp;#10;action_pending_log_by_id = {}&amp;#10;drain_thread_results(decoder_thread, stim_thread)&amp;#10;&amp;#10;if stimulator_enabled and stimulator is not None and getattr(stimulator, &quot;is_stimulating&quot;, False):&amp;#10;    try:&amp;#10;        stimulator.stop_stimulation()&amp;#10;    except Exception as e:&amp;#10;        print_timeline(&quot;STIM-WARN&quot;, f&quot;stop residual stimulation failed at action begin: {e}&quot;)&amp;#10;&amp;#10;stim_start_pending = False&amp;#10;stim_start_decode_id = None&amp;#10;stim_window_active = False&amp;#10;stim_window_decode_id = None&amp;#10;stim_window_row_idx = None&amp;#10;stim_window_command_label = &quot;&quot;&amp;#10;stim_window_params = None&amp;#10;stim_window_deadline_s = 0.0&amp;#10;&amp;#10;stim_stop_pending = False&amp;#10;stim_stop_decode_id = None&amp;#10;&amp;#10;fs = int(decoder_cfg[&quot;fs&quot;])&amp;#10;step_points = int(decode_interval_s * fs)&amp;#10;window_points = int(decode_window_s * fs)&amp;#10;expected_channels = 128&amp;#10;&amp;#10;participant_id = expInfo.get(&quot;participant&quot;, &quot;unknown&quot;)&amp;#10;session_id = expInfo.get(&quot;session&quot;, &quot;001&quot;)&amp;#10;action_log_file_path = build_action_log_path(action_decode_log_dir, participant_id, session_id)&amp;#10;action_decode_window = to_data_window(dc.get_data(window_points), expected_channels)&amp;#10;&amp;#10;print_timeline(&amp;#10;    &quot;ROUTINE-ACTION-BEGIN&quot;,&amp;#10;    (&amp;#10;        f&quot;video={video_name} | init_window={tuple(action_decode_window.shape)} | &quot;&amp;#10;        f&quot;decode_interval={decode_interval_s}s | decode_window={decode_window_s}s | &quot;&amp;#10;        f&quot;stim_duration={stim_duration_ms}ms&quot;&amp;#10;    ),&amp;#10;    action_time_s=0.0,&amp;#10;)&amp;#10;&amp;#10;# &amp;#10;act_movie.setMovie(act_movie_dir)&amp;#10;act_sound.setSound(act_sound_dir, secs=3, hamming=True)&amp;#10;act_sound.setVolume(1.0, log=False)&amp;#10;act_sound.seek(0)&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="action_now_s = monotonic_time_s()&amp;#10;&amp;#10;# 1. 刺激窗口结束，提交 stop&amp;#10;if stim_window_active and action_now_s &gt;= stim_window_deadline_s:&amp;#10;    stim_window_active = False&amp;#10;&amp;#10;    start_time = stim_window_deadline_s - stim_duration_ms / 1000.0&amp;#10;    print_timeline(&amp;#10;        &quot;STIM-WINDOW-END&quot;,&amp;#10;        (&amp;#10;            f&quot;id={stim_window_decode_id} | window={start_time:.3f}s-{stim_window_deadline_s:.3f}s | &quot;&amp;#10;            f&quot;duration={stim_duration_ms}ms&quot;&amp;#10;        ),&amp;#10;        action_time_s=action_now_s,&amp;#10;    )&amp;#10;&amp;#10;    if (not stim_stop_pending) and stim_window_params is not None:&amp;#10;        stop_submit_ok = stim_thread.submit(&amp;#10;            decode_id=stim_window_decode_id,&amp;#10;            command_type=&quot;stop&quot;,&amp;#10;            params=stim_window_params,&amp;#10;            command_label=stim_window_command_label,&amp;#10;        )&amp;#10;&amp;#10;        if stop_submit_ok:&amp;#10;            stim_stop_pending = True&amp;#10;            stim_stop_decode_id = stim_window_decode_id&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-STOP-SUBMIT&quot;,&amp;#10;                f&quot;id={stim_window_decode_id} | label={stim_window_command_label}&quot;,&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;        else:&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-STOP-SKIP&quot;,&amp;#10;                f&quot;id={stim_window_decode_id} | reason=stim_thread_busy_or_queue_full&quot;,&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;# 2. 每100ms取一次数据，提交解码&amp;#10;if (action_now_s - action_last_fetch_s) &gt;= decode_interval_s:&amp;#10;    new_chunk = dc.get_data(step_points)&amp;#10;    current_new_chunk_shape = &quot;&quot;&amp;#10;    action_last_fetch_s = action_now_s&amp;#10;&amp;#10;    action_decode_window, current_new_chunk_shape = merge_new_chunk(&amp;#10;        action_decode_window,&amp;#10;        new_chunk,&amp;#10;        window_points,&amp;#10;    )&amp;#10;&amp;#10;    if (&amp;#10;        action_decode_window.ndim == 2&amp;#10;        and action_decode_window.shape[1] &gt;= window_points&amp;#10;        and not decoder_thread.is_busy()&amp;#10;    ):&amp;#10;        decode_id = global_decode_id&amp;#10;        decode_input = action_decode_window[:, -window_points:]&amp;#10;&amp;#10;        submit_ok = decoder_thread.submit(&amp;#10;            decode_id=decode_id,&amp;#10;            data=decode_input,&amp;#10;            timestamp_s=action_now_s,&amp;#10;        )&amp;#10;&amp;#10;        if submit_ok:&amp;#10;            global_decode_id += 1&amp;#10;            action_pending_chunk_shape_by_id[decode_id] = current_new_chunk_shape&amp;#10;            print_timeline(&amp;#10;                &quot;DECODE-SUBMIT&quot;,&amp;#10;                f&quot;id={decode_id} | chunk={current_new_chunk_shape} | window={tuple(decode_input.shape)}&quot;,&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;# 3. 处理解码结果，决定是否触发刺激&amp;#10;decode_payload = decoder_thread.consume_result()&amp;#10;&amp;#10;if decode_payload is not None:&amp;#10;    action_decode_count += 1&amp;#10;    decode_id = decode_payload[&quot;decode_id&quot;]&amp;#10;    decode_result = decode_payload[&quot;result&quot;]&amp;#10;&amp;#10;    predicted_target = decode_result.get(&quot;predicted_target&quot;, None)&amp;#10;    decode_success = bool(decode_result.get(&quot;success&quot;, False))&amp;#10;&amp;#10;    preprocess_time_ms = decode_payload.get(&quot;preprocess_time_ms&quot;, &quot;&quot;)&amp;#10;    feature_time_ms = decode_payload.get(&quot;feature_time_ms&quot;, &quot;&quot;)&amp;#10;    model_infer_time_ms = decode_payload.get(&quot;model_infer_time_ms&quot;, &quot;&quot;)&amp;#10;&amp;#10;    total_pipeline_time_ms = &quot;&quot;&amp;#10;    if (&amp;#10;        preprocess_time_ms is not None&amp;#10;        and feature_time_ms is not None&amp;#10;        and model_infer_time_ms is not None&amp;#10;    ):&amp;#10;        total_pipeline_time_ms = round(&amp;#10;            float(preprocess_time_ms) + float(feature_time_ms) + float(model_infer_time_ms),&amp;#10;            3&amp;#10;        )&amp;#10;&amp;#10;    log_decode_event(&amp;#10;        decode_payload,&amp;#10;        decode_result,&amp;#10;        total_pipeline_time_ms,&amp;#10;        action_time_s=action_now_s,&amp;#10;    )&amp;#10;&amp;#10;    new_chunk_shape = action_pending_chunk_shape_by_id.pop(decode_id, &quot;&quot;)&amp;#10;&amp;#10;    want_stim = decode_success and (predicted_target == 1 or predicted_target == 0)&amp;#10;    should_stim = int(want_stim)&amp;#10;    stim_submit_ok = 0&amp;#10;    command_label = &quot;&quot;&amp;#10;    stim_error = &quot;&quot;&amp;#10;&amp;#10;    if want_stim:&amp;#10;        command_label = f&quot;stim_target_{predicted_target}_{stim_duration_ms}ms&quot;&amp;#10;&amp;#10;        if not stimulator_enabled or stimulator is None:&amp;#10;            stim_error = &quot;stimulator_not_enabled&quot;&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-START-SKIP&quot;,&amp;#10;                (&amp;#10;                    f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                    f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                    f&quot;reason=stimulator_not_enabled&quot;&amp;#10;                ),&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;        elif stim_start_pending:&amp;#10;            stim_error = &quot;stim_start_pending&quot;&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-START-SKIP&quot;,&amp;#10;                (&amp;#10;                    f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                    f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                    f&quot;reason=stim_start_pending&quot;&amp;#10;                ),&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;        elif stim_window_active:&amp;#10;            stim_error = &quot;stim_is_busy&quot;&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-START-SKIP&quot;,&amp;#10;                (&amp;#10;                    f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                    f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                    f&quot;reason=stim_window_active&quot;&amp;#10;                ),&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;        elif stim_stop_pending:&amp;#10;            stim_error = &quot;stim_stop_pending&quot;&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-START-SKIP&quot;,&amp;#10;                (&amp;#10;                    f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                    f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                    f&quot;reason=stim_stop_pending&quot;&amp;#10;                ),&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;        elif stim_thread.is_busy():&amp;#10;            stim_error = &quot;stim_thread_busy&quot;&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-START-SKIP&quot;,&amp;#10;                (&amp;#10;                    f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                    f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                    f&quot;reason=stim_thread_busy&quot;&amp;#10;                ),&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;&amp;#10;        else:&amp;#10;            params = stim_param_map.get(predicted_target, None)&amp;#10;&amp;#10;            if params is None:&amp;#10;                stim_error = &quot;stim_params_missing&quot;&amp;#10;                print_timeline(&amp;#10;                    &quot;STIM-START-SKIP&quot;,&amp;#10;                    (&amp;#10;                        f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                        f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                        f&quot;reason=stim_params_missing&quot;&amp;#10;                    ),&amp;#10;                    action_time_s=action_now_s,&amp;#10;                )&amp;#10;            else:&amp;#10;                stim_submit_ok = int(&amp;#10;                    stim_thread.submit(&amp;#10;                        decode_id=decode_id,&amp;#10;                        command_type=&quot;start&quot;,&amp;#10;                        params=params,&amp;#10;                        command_label=command_label,&amp;#10;                    )&amp;#10;                )&amp;#10;&amp;#10;                if stim_submit_ok:&amp;#10;                    stim_start_pending = True&amp;#10;                    stim_start_decode_id = decode_id&amp;#10;                    stim_window_decode_id = decode_id&amp;#10;                    stim_window_row_idx = None&amp;#10;                    stim_window_command_label = command_label&amp;#10;                    stim_window_params = params&amp;#10;                    stim_window_deadline_s = 0.0&amp;#10;                    stim_stop_pending = False&amp;#10;                    stim_stop_decode_id = None&amp;#10;&amp;#10;                    print_timeline(&amp;#10;                        &quot;STIM-START-SUBMIT&quot;,&amp;#10;                        (&amp;#10;                            f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                            f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                            f&quot;command={command_label}&quot;&amp;#10;                        ),&amp;#10;                        action_time_s=action_now_s,&amp;#10;                    )&amp;#10;&amp;#10;                else:&amp;#10;                    stim_error = &quot;stim_is_busy&quot;&amp;#10;                    print_timeline(&amp;#10;                        &quot;STIM-START-SKIP&quot;,&amp;#10;                        (&amp;#10;                            f&quot;id={decode_id} | target={predicted_target} | &quot;&amp;#10;                            f&quot;conf={decode_result.get('confidence', 0):.4f} | &quot;&amp;#10;                            f&quot;reason=stim_thread_queue_full&quot;&amp;#10;                        ),&amp;#10;                        action_time_s=action_now_s,&amp;#10;                    )&amp;#10;&amp;#10;    log_row = build_decode_log_row(&amp;#10;        expInfo,&amp;#10;        action_start_time_s,&amp;#10;        action_now_s,&amp;#10;        decode_payload,&amp;#10;        decode_result,&amp;#10;        new_chunk_shape,&amp;#10;        total_pipeline_time_ms,&amp;#10;        should_stim,&amp;#10;        stim_submit_ok,&amp;#10;        command_label,&amp;#10;        stim_error,&amp;#10;    )&amp;#10;&amp;#10;    action_log_cache.append(log_row)&amp;#10;&amp;#10;    if stim_submit_ok:&amp;#10;        action_pending_log_by_id[decode_id] = len(action_log_cache) - 1&amp;#10;        stim_window_row_idx = len(action_log_cache) - 1&amp;#10;&amp;#10;# 4. 回填刺激线程结果&amp;#10;stim_payload = stim_thread.consume_result()&amp;#10;&amp;#10;if stim_payload is not None:&amp;#10;    log_stim_payload(stim_payload, action_time_s=action_now_s)&amp;#10;    decode_id = stim_payload.get(&quot;decode_id&quot;, None)&amp;#10;    command_type = stim_payload.get(&quot;command_type&quot;, &quot;&quot;)&amp;#10;    command_sent = bool(stim_payload.get(&quot;command_sent&quot;, 0))&amp;#10;    apply_stim_payload_to_logs(action_log_cache, action_pending_log_by_id, stim_payload)&amp;#10;&amp;#10;    if command_type == &quot;start&quot; and decode_id == stim_start_decode_id:&amp;#10;        stim_start_pending = False&amp;#10;        stim_start_decode_id = None&amp;#10;&amp;#10;        if command_sent:&amp;#10;            stim_window_active = True&amp;#10;            stim_window_deadline_s = action_now_s + stim_duration_ms / 1000.0&amp;#10;            print_timeline(&amp;#10;                &quot;STIM-WINDOW-START&quot;,&amp;#10;                (&amp;#10;                    f&quot;id={decode_id} | actual_window={action_now_s:.3f}s-&quot;&amp;#10;                    f&quot;{stim_window_deadline_s:.3f}s | duration={stim_duration_ms}ms&quot;&amp;#10;                ),&amp;#10;                action_time_s=action_now_s,&amp;#10;            )&amp;#10;        else:&amp;#10;            stim_window_active = False&amp;#10;            stim_window_decode_id = None&amp;#10;            stim_window_row_idx = None&amp;#10;            stim_window_command_label = &quot;&quot;&amp;#10;            stim_window_params = None&amp;#10;            stim_window_deadline_s = 0.0&amp;#10;&amp;#10;    if command_type == &quot;stop&quot; and decode_id == stim_stop_decode_id:&amp;#10;        stim_window_active = False&amp;#10;        stim_stop_pending = False&amp;#10;        stim_stop_decode_id = None&amp;#10;&amp;#10;        stim_window_decode_id = None&amp;#10;        stim_window_row_idx = None&amp;#10;        stim_window_command_label = &quot;&quot;&amp;#10;        stim_window_params = None&amp;#10;        stim_window_deadline_s = 0.0&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="action_end_time_s = monotonic_time_s()&amp;#10;print_timeline(&amp;#10;    &quot;ROUTINE-ACTION-END&quot;,&amp;#10;    f&quot;decodes={action_decode_count} | log_rows={len(action_log_cache)}&quot;,&amp;#10;    action_time_s=action_end_time_s - action_start_time_s,&amp;#10;)&amp;#10;&amp;#10;if stim_window_active:&amp;#10;    stim_window_active = False&amp;#10;&amp;#10;if (not stim_stop_pending) and stim_window_params is not None:&amp;#10;    stop_submit_ok = stim_thread.submit(&amp;#10;        decode_id=stim_window_decode_id if stim_window_decode_id is not None else -1,&amp;#10;        command_type=&quot;stop&quot;,&amp;#10;        params=stim_window_params,&amp;#10;        command_label=stim_window_command_label,&amp;#10;    )&amp;#10;    if stop_submit_ok:&amp;#10;        stim_stop_pending = True&amp;#10;        stim_stop_decode_id = stim_window_decode_id&amp;#10;        print_timeline(&amp;#10;            &quot;STIM-STOP-FINALIZE&quot;,&amp;#10;            f&quot;id={stim_window_decode_id} | label={stim_window_command_label}&quot;,&amp;#10;            action_time_s=action_end_time_s - action_start_time_s,&amp;#10;        )&amp;#10;    else:&amp;#10;        print_timeline(&amp;#10;            &quot;STIM-STOP-FINALIZE-SKIP&quot;,&amp;#10;            f&quot;id={stim_window_decode_id} | reason=stop_queue_full&quot;,&amp;#10;            action_time_s=action_end_time_s - action_start_time_s,&amp;#10;        )&amp;#10;&amp;#10;if stim_stop_pending and stim_thread.is_busy() and stim_window_params is not None:&amp;#10;    print_timeline(&amp;#10;        &quot;STIM-STOP-DRAIN-WAIT&quot;,&amp;#10;        f&quot;id={stim_stop_decode_id} | waiting_for_busy_thread&quot;,&amp;#10;        action_time_s=action_end_time_s - action_start_time_s,&amp;#10;    )&amp;#10;&amp;#10;drain_deadline = time.perf_counter() + 0.8&amp;#10;&amp;#10;while time.perf_counter() &lt; drain_deadline:&amp;#10;    stim_payload = stim_thread.consume_result()&amp;#10;&amp;#10;    if stim_payload is None:&amp;#10;        core.wait(0.01)&amp;#10;        continue&amp;#10;&amp;#10;    decode_id = stim_payload.get(&quot;decode_id&quot;, None)&amp;#10;    command_type = stim_payload.get(&quot;command_type&quot;, &quot;&quot;)&amp;#10;    command_sent = bool(stim_payload.get(&quot;command_sent&quot;, 0))&amp;#10;    log_stim_payload(&amp;#10;        stim_payload,&amp;#10;        action_time_s=action_end_time_s - action_start_time_s,&amp;#10;    )&amp;#10;    apply_stim_payload_to_logs(action_log_cache, action_pending_log_by_id, stim_payload)&amp;#10;&amp;#10;    if command_type == &quot;start&quot; and decode_id == stim_start_decode_id:&amp;#10;        stim_start_pending = False&amp;#10;        stim_start_decode_id = None&amp;#10;        if command_sent:&amp;#10;            stim_window_active = True&amp;#10;        else:&amp;#10;            stim_window_active = False&amp;#10;            stim_window_decode_id = None&amp;#10;            stim_window_row_idx = None&amp;#10;            stim_window_command_label = &quot;&quot;&amp;#10;            stim_window_params = None&amp;#10;            stim_window_deadline_s = 0.0&amp;#10;&amp;#10;    if command_type == &quot;stop&quot; and decode_id == stim_stop_decode_id:&amp;#10;        stim_window_active = False&amp;#10;        stim_stop_pending = False&amp;#10;        stim_stop_decode_id = None&amp;#10;        stim_window_decode_id = None&amp;#10;        stim_window_row_idx = None&amp;#10;        stim_window_command_label = &quot;&quot;&amp;#10;        stim_window_params = None&amp;#10;        stim_window_deadline_s = 0.0&amp;#10;&amp;#10;if (&amp;#10;    stimulator_enabled&amp;#10;    and stimulator is not None&amp;#10;    and getattr(stimulator, &quot;is_stimulating&quot;, False)&amp;#10;    and stim_window_params is not None&amp;#10;):&amp;#10;    print_timeline(&amp;#10;        &quot;STIM-STOP-FORCE&quot;,&amp;#10;        f&quot;id={stim_window_decode_id} | direct_stop_after_drain&quot;,&amp;#10;        action_time_s=action_end_time_s - action_start_time_s,&amp;#10;    )&amp;#10;    force_stop_ok = stim_thread.force_stop_now(&amp;#10;        decode_id=stim_window_decode_id if stim_window_decode_id is not None else -1,&amp;#10;        params=stim_window_params,&amp;#10;        command_label=stim_window_command_label or &quot;force_stop_after_action&quot;,&amp;#10;    )&amp;#10;    print_timeline(&amp;#10;        &quot;STIM-STOP-FORCE-RESULT&quot;,&amp;#10;        f&quot;id={stim_window_decode_id} | sent={int(force_stop_ok)}&quot;,&amp;#10;        action_time_s=action_end_time_s - action_start_time_s,&amp;#10;    )&amp;#10;    extra_stim_payload = stim_thread.consume_result()&amp;#10;    if extra_stim_payload is not None:&amp;#10;        log_stim_payload(&amp;#10;            extra_stim_payload,&amp;#10;            action_time_s=action_end_time_s - action_start_time_s,&amp;#10;        )&amp;#10;        apply_stim_payload_to_logs(action_log_cache, action_pending_log_by_id, extra_stim_payload)&amp;#10;    if force_stop_ok:&amp;#10;        stim_start_pending = False&amp;#10;        stim_start_decode_id = None&amp;#10;        stim_stop_pending = False&amp;#10;        stim_stop_decode_id = None&amp;#10;        stim_window_decode_id = None&amp;#10;        stim_window_row_idx = None&amp;#10;        stim_window_command_label = &quot;&quot;&amp;#10;        stim_window_params = None&amp;#10;        stim_window_deadline_s = 0.0&amp;#10;&amp;#10;if stim_stop_pending and stim_window_row_idx is not None:&amp;#10;    if 0 &lt;= stim_window_row_idx &lt; len(action_log_cache):&amp;#10;        old_error = action_log_cache[stim_window_row_idx].get(&quot;stim_error&quot;, &quot;&quot;)&amp;#10;        if not old_error:&amp;#10;            action_log_cache[stim_window_row_idx][&quot;stim_error&quot;] = &quot;stop_result_pending_when_action_end&quot;&amp;#10;&amp;#10;for row in action_log_cache:&amp;#10;    row[&quot;action_end_time_s&quot;] = round(action_end_time_s, 6)&amp;#10;&amp;#10;try:&amp;#10;    save_action_decode_logs(action_log_cache, action_log_file_path)&amp;#10;    print_timeline(&amp;#10;        &quot;ACTION-LOG-SAVED&quot;,&amp;#10;        f&quot;path={action_log_file_path} | rows={len(action_log_cache)}&quot;,&amp;#10;        action_time_s=action_end_time_s - action_start_time_s,&amp;#10;    )&amp;#10;except Exception as e:&amp;#10;    print_timeline(&quot;ACTION-LOG-ERROR&quot;, f&quot;save_action_decode_logs failed: {e}&quot;)&amp;#10;" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="act_code" valType="code" updates="None" name="name"/>
      </CodeComponent>
