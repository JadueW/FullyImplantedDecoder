  <Flow>
    <Routine name="initialization"/>
    <LoopInitiator loopType="TrialHandler" name="block_loop">
      <Param name="Selected rows" updates="None" val="0" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('block_order', 1), ('block_stimuli', '保持腿部\n伸展平放'), ('block_dir', 'contents\\audios\\请保持腿部伸展平放.wav')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="block_condition.csv" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="block_repeats" valType="num"/>
      <Param name="name" updates="None" val="block_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="block_tips"/>
    <LoopInitiator loopType="TrialHandler" name="trial_loop">
      <Param name="Selected rows" updates="None" val="$selected_rows" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('order', 1), ('stimuli', '准备翻动手掌'), ('dir', 'contents\\audios\\准备翻动手掌.wav')]), OrderedDict([('order', 2), ('stimuli', '准备抓握'), ('dir', 'contents\\audios\\准备抓握.wav')]), OrderedDict([('order', 3), ('stimuli', '准备向内勾手腕'), ('dir', 'contents\\audios\\准备向内勾手腕.wav')]), OrderedDict([('order', 4), ('stimuli', '准备抬小臂'), ('dir', 'contents\\audios\\准备抬小臂.wav')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="$conditions_file" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="trial_repeats" valType="num"/>
      <Param name="name" updates="None" val="trial_loop" valType="code"/>
      <Param name="random seed" updates="None" val="random_seed" valType="code"/>
    </LoopInitiator>
    <Routine name="tips"/>
    <Routine name="action"/>
    <Routine name="reset"/>
    <LoopTerminator name="trial_loop"/>
    <Routine name="block_end"/>
    <LoopTerminator name="block_loop"/>
    <Routine name="end"/>
  </Flow>
</PsychoPy2experiment>
