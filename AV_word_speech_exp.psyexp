      <CodeComponent name="tqdm" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="from tqdm import tqdm&amp;#10;global trial_bar &amp;#10;print(&quot;block_repeats&quot;, block_repeats)&amp;#10;print(&quot;corpus_repeats&quot;, trial_repeats)&amp;#10;&amp;#10;total_trials = block_repeats * trial_repeats * corpus_num&amp;#10;&amp;#10;&amp;#10;# 初始化进度条，描述文本将在后面动态更新&amp;#10;trial_bar = tqdm(total=total_trials, desc=&quot;实验准备中...&quot;)&amp;#10;&amp;#10;&amp;#10;print(&quot;begin exp&quot;)&amp;#10;" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="/* Syntax Error: Fix Python code */" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="trial_bar.update(1);&amp;#10;if ((corpus_loop.thisN === 0)) {&amp;#10;    current_block = (block_loop.thisN + 1);&amp;#10;    total_blocks = block_loop.nTotal;&amp;#10;    desc_text = `block进度：${current_block}/${total_blocks}，总进度`;&amp;#10;    trial_bar.set_description(desc_text);&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# 1. 首先，为即将开始的这个 trial 更新进度条&amp;#10;#    让进度条的数值（如 11/25 -&gt; 12/25）先行一步&amp;#10;trial_bar.update(1)&amp;#10;&amp;#10;# 2. 然后，检查这是否是一个新 block 的开始&amp;#10;#    PsychoPy 会自动创建名为 block_loop 和 trials 的循环处理器&amp;#10;if corpus_loop.thisN == 0:&amp;#10;    # 获取当前 block 的编号 (thisN 从0开始，所以+1)&amp;#10;    current_block = block_loop.thisN + 1&amp;#10;    # 获取总 block 数&amp;#10;    total_blocks = block_loop.nTotal&amp;#10;    &amp;#10;    # 构建新的描述文本&amp;#10;    desc_text = f&quot;block进度：{current_block}/{total_blocks}，总进度&quot;&amp;#10;    &amp;#10;    # 更新描述。这会再次刷新屏幕，但此时进度条的数值已经是正确的了&amp;#10;    trial_bar.set_description(desc_text)&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="trial_bar.close()" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="trial_bar.close();&amp;#10;" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="tqdm" valType="code" updates="None" name="name"/>
      </CodeComponent>
