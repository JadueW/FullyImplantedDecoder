  <Flow>
    <Routine name="initialization"/>
    <LoopInitiator loopType="TrialHandler" name="block_loop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('block_id', None)]), OrderedDict([('block_id', None)])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="block_repeats" valType="num"/>
      <Param name="name" updates="None" val="block_loop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="block_start"/>
    <LoopInitiator loopType="TrialHandler" name="corpus_loop">
      <Param name="Selected rows" updates="None" val="$selected_rows" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('corpus_order', 1), ('wl_corpus', '你')]), OrderedDict([('corpus_order', 2), ('wl_corpus', '你们')]), OrderedDict([('corpus_order', 3), ('wl_corpus', '我')]), OrderedDict([('corpus_order', 4), ('wl_corpus', '我们')]), OrderedDict([('corpus_order', 5), ('wl_corpus', '他')]), OrderedDict([('corpus_order', 6), ('wl_corpus', '他们')]), OrderedDict([('corpus_order', 7), ('wl_corpus', '好')]), OrderedDict([('corpus_order', 8), ('wl_corpus', '开心')]), OrderedDict([('corpus_order', 9), ('wl_corpus', '认识')]), OrderedDict([('corpus_order', 10), ('wl_corpus', '大家')])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="$conditions_file" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="trial_repeats" valType="num"/>
      <Param name="name" updates="None" val="corpus_loop" valType="code"/>
      <Param name="random seed" updates="None" val="random_seed" valType="code"/>
    </LoopInitiator>
    <Routine name="speech_corpus"/>
    <LoopTerminator name="corpus_loop"/>
    <Routine name="block_end"/>
    <LoopTerminator name="block_loop"/>
    <Routine name="over"/>
  </Flow>
</PsychoPy2experiment>
